{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Packet",
  "description": "A single entry in the Field Kit catalog",
  "type": "object",
  "required": [
    "id",
    "title",
    "description",
    "packetType",
    "publishState",
    "discoverability",
    "tags"
  ],
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique identifier (kebab-case slug)"
    },
    "title": {
      "type": "string",
      "description": "Human-readable title of the packet"
    },
    "packetType": {
      "type": "string",
      "description": "Expertise/audience level. Determines issue template and display.",
      "enum": [
        "100 — Sales & General",
        "200 — Solutioning & Training",
        "300 — Delivery & Usage",
        "400 — Debugging & Niche"
      ]
    },
    "issueTemplate": {
      "type": "string",
      "description": "Filename of the GitHub Issue template for proposing this packet type"
    },
    "description": {
      "type": "string",
      "description": "Summary of what this packet contains and its purpose"
    },
    "maintainer": {
      "type": "string",
      "description": "GitHub username or team responsible for this packet"
    },
    "created": {
      "type": "string",
      "format": "date"
    },
    "updated": {
      "type": "string",
      "format": "date"
    },
    "issueNumber": {
      "type": "integer",
      "description": "GitHub issue number that originated this packet (set automatically by the PR workflow)"
    },
    "publishState": {
      "type": "string",
      "enum": [
        "Published",
        "Archived",
        "Deprecated"
      ]
    },
    "discoverability": {
      "type": "string",
      "enum": [
        "Internal",
        "Partner",
        "Public"
      ]
    },
    "tags": {
      "type": "object",
      "properties": {
        "industry": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "productLine": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "thirdPartySoftware": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "language": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "technicalDomain": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "custom": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "contentGroups": {
      "type": "array",
      "description": "Groups of content items that can be dynamically loaded",
      "items": {
        "type": "object",
        "required": [
          "title"
        ],
        "properties": {
          "title": {
            "type": "string",
            "description": "Display name of this content group"
          },
          "description": {
            "type": "string"
          },
          "sourceUrl": {
            "type": "string",
            "format": "uri",
            "description": "URL to fetch content from (e.g., raw GitHub README)"
          },
          "baseUrl": {
            "type": "string",
            "format": "uri",
            "description": "Base URL for resolving relative links"
          },
          "parser": {
            "type": "string",
            "enum": [
              "markdown-table",
              "directory-list"
            ],
            "description": "How to parse the fetched content"
          }
        }
      }
    },
    "resources": {
      "type": "object",
      "properties": {
        "labPackage": {
          "type": "object",
          "properties": {
            "cognitionEnv": {
              "type": "array",
              "items": {
                "$ref": "#/definitions/resource"
              }
            },
            "customerEnv": {
              "type": "array",
              "items": {
                "$ref": "#/definitions/resource"
              }
            }
          }
        },
        "setupGuide": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/resource"
          }
        },
        "media": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/resource"
          }
        }
      }
    }
  },
  "definitions": {
    "resource": {
      "type": "object",
      "required": [
        "title",
        "type",
        "url"
      ],
      "properties": {
        "title": {
          "type": "string"
        },
        "type": {
          "type": "string",
          "enum": [
            "github-repo",
            "html",
            "devin-session",
            "google-doc",
            "video",
            "notion",
            "other"
          ]
        },
        "url": {
          "type": "string",
          "format": "uri"
        },
        "description": {
          "type": "string"
        },
        "access": {
          "type": "string",
          "enum": [
            "public",
            "protected"
          ]
        }
      }
    }
  }
}
